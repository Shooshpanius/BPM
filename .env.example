# ==============================================================================
# Переменные окружения CoreBPM
# Скопируйте этот файл в .env и заполните значения.
#
# Соглашение об именовании:
#   BPM_S_*  — переменные серверной части (ASP.NET Core)
#   BPM_C_*  — переменные клиентской части (Vite/React)
#
# Чтобы ASP.NET Core читал переменные с префиксом BPM_S_,
# добавьте в Program.cs:
#   builder.Configuration.AddEnvironmentVariables("BPM_S_");
# После этого BPM_S_ConnectionStrings__DefaultConnection
# будет доступно как ConnectionStrings:DefaultConnection.
# ==============================================================================

# ------------------------------------------------------------------------------
# Серверные переменные (BPM_S_)
# ------------------------------------------------------------------------------

# Обязательно: пароль для базы данных PostgreSQL
BPM_S_DB_PASSWORD=changeme

# Имя базы данных (по умолчанию: corebpm)
BPM_S_DB_NAME=corebpm

# Пользователь базы данных (по умолчанию: corebpm)
BPM_S_DB_USER=corebpm

# JWT-секрет для подписи токенов (минимум 32 символа)
BPM_S_Jwt__SecretKey=your-very-secret-key-at-least-32-chars

# Издатель и аудитория JWT (по умолчанию: CoreBPM)
BPM_S_Jwt__Issuer=CoreBPM
BPM_S_Jwt__Audience=CoreBPM

# Время жизни access-токена в минутах (по умолчанию: 30)
BPM_S_Jwt__AccessTokenLifetimeMinutes=30

# Время жизни refresh-токена в днях (по умолчанию: 7)
BPM_S_Jwt__RefreshTokenExpirationDays=7

# ------------------------------------------------------------------------------
# Клиентские переменные (BPM_C_)
# Переменные, начинающиеся с BPM_C_, доступны в коде React как:
#   import.meta.env.BPM_C_*
# ------------------------------------------------------------------------------

# Порт, на котором будет доступен клиент (по умолчанию: 80)
BPM_C_PORT=80

# Пример feature-флага (раскомментируйте при необходимости)
# BPM_C_ENABLE_SOME_FEATURE=true
